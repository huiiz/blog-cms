---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostMeta from '@/components/PostMeta.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group by year
const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="归档" description="文章归档">
  <h1 class="text-3xl font-bold mb-8">归档</h1>

  <p class="text-gray-500 mb-8">共 {posts.length} 篇文章</p>

  <div class="space-y-12">
    {years.map((year) => (
      <section>
        <h2 class="text-2xl font-bold mb-4 text-primary-600">{year}</h2>
        <div class="space-y-3">
          {postsByYear[Number(year)].map((post) => (
            <a
              href={`/posts/${post.id}`}
              class="group flex items-baseline gap-4 py-2 border-b border-gray-100 dark:border-gray-800 hover:border-primary-500 transition-colors"
            >
              <span class="text-gray-400 text-sm shrink-0">
                {post.data.date.toISOString().slice(5, 10)}
              </span>
              <span class="group-hover:text-primary-600 transition-colors">
                {post.data.title}
              </span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
