---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group by category
const categories = posts.reduce((acc, post) => {
  const cat = post.data.category || '未分类';
  if (!acc[cat]) acc[cat] = 0;
  acc[cat]++;
  return acc;
}, {} as Record<string, number>);

const sortedCategories = Object.entries(categories).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="分类" description="文章分类">
  <h1 class="text-3xl font-bold mb-8">分类</h1>

  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {sortedCategories.map(([name, count]) => (
      <a
        href={`/categories/${encodeURIComponent(name)}`}
        class="p-6 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-primary-500 dark:hover:border-primary-500 transition-colors group"
      >
        <h2 class="text-xl font-bold mb-2 group-hover:text-primary-600 transition-colors">
          {name}
        </h2>
        <p class="text-gray-500">{count} 篇文章</p>
      </a>
    ))}
  </div>
</BaseLayout>
