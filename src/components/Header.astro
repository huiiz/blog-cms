---
import ThemeToggle from './ThemeToggle.astro';
import SearchButton from './SearchButton.astro';
---

<header class="border-b border-gray-200 dark:border-gray-800 sticky top-0 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md z-50">
  <nav class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold hover:text-primary-600 transition-colors">
      博客
    </a>

    <div class="flex items-center gap-6">
      <div class="hidden md:flex items-center gap-6">
        <a href="/archives" class="hover:text-primary-600 transition-colors">归档</a>
        <a href="/categories" class="hover:text-primary-600 transition-colors">分类</a>
        <a href="/tags" class="hover:text-primary-600 transition-colors">标签</a>
        <a href="/about" class="hover:text-primary-600 transition-colors">关于</a>
      </div>

      <div class="flex items-center gap-3">
        <SearchButton />
        <ThemeToggle />
        <a
          href="/dashboard"
          class="px-3 py-1.5 text-sm bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors"
        >
          管理
        </a>
      </div>
    </div>
  </nav>
</header>
