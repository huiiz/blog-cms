  <div class="max-w-4xl mx-auto px-4 text-center text-gray-500">
    <p>&copy; {currentYear} 博客. 使用 <a href="https://astro.build" class="text-primary-600 hover:underline">Astro</a> + <a href="https://tina.io" class="text-primary-600 hover:underline">TinaCMS</a> 构建</p>
    <p class="mt-2 text-sm">
      <a href="/rss.xml" class="hover:text-primary-600">RSS</a>
      <span class="mx-2">·</span>
      <a href="https://github.com" class="hover:text-primary-600">GitHub</a>
    </p>
  </div>
</footer>
